---
import { Image } from "astro:assets";
import logo from '../assets/pumpkinHead-a_75.png';

---
<nav class="bg-white/80 dark:bg-[#0a0a0c]/80 backdrop-blur-lg border-b border-slate-200 dark:border-white/5 sticky top-0 z-50 transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <a href="/" class="text-3xl font-['Oswald'] font-bold text-slate-900 dark:text-white tracking-tighter flex items-center ">
            <Image 
              src={logo} 
              alt="VeloAstro Logo" 
              width={40} 
              height={40}
              class="rounded-full" />
          <span class="text-main-orange-500 me-0 pe-0">PMPKN</span>.CC
        </a>
        <div class="hidden md:flex gap-8 font-semibold text-sm uppercase tracking-wider text-slate-600 dark:text-slate-300">
          <a href="/trasy-rowerowe" class="hover:text-main-orange-500 transition relative group py-2">
            Trasy rowerowe
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-main-orange-500 transition-all group-hover:w-full"></span>
          </a>
          <a href="/blog" class="hover:text-main-orange-500 transition relative group py-2">
            Blog
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-main-orange-500 transition-all group-hover:w-full"></span>
          </a>
          
        </div>
        <div class="flex items-center gap-4">
          <button id="theme-toggle" type="button" aria-label="Dzień/Noc" class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg text-sm p-2.5 transition focus:outline-none">
            <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="https://www.w3.org/2000/svg"><path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path></svg>
            <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="https://www.w3.org/2000/svg"><path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" fill-rule="evenodd" clip-rule="evenodd"></path></svg>
          </button>
          <a href="https://www.strava.com/athletes/pmpkn" target="_blank" rel="noopener noreferrer"class="hidden md:block bg-strava hover:bg-strava-hover text-white px-5 py-2.5 rounded-full font-bold text-sm transition transform hover:scale-105">
            Strava
          </a>
          <div class="md:hidden flex items-center">
            <button id="mobile-menu-button" type="button" aria-label="Menu" class="text-slate-500 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg text-sm p-2.5 transition focus:outline-none" aria-controls="mobile-menu" aria-expanded="false">
              <span class="sr-only">Otwórz główne menu</span>
              <svg id="menu-open-icon" class="w-6 h-6 block" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="https://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M3 5a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 10a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zM3 15a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>
              <svg id="menu-close-icon" class="hidden w-6 h-6" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="https://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
            </button>
          </div>
        </div>
      </div>
      <!-- Mobile menu, show/hide based on menu state. -->
      <div class="hidden md:hidden" id="mobile-menu">
        <div class="px-6 pb-4 space-y-2">
          <a href="/blog" class="block py-2 font-semibold text-slate-600 dark:text-slate-300 hover:text-orange-500 transition">Blog</a>
          <a href="/trasy" class="block py-2 font-semibold text-slate-600 dark:text-slate-300 hover:text-orange-500 transition">Trasy</a>
          <a href="/sprzet" class="block py-2 font-semibold text-slate-600 dark:text-slate-300 hover:text-orange-500 transition">Sprzęt</a>
          <a href="https://www.strava.com/athletes/pmpkn" target="_blank" rel="noopener noreferrer" class="block mt-4 text-center bg-orange-600 hover:bg-orange-700 text-white px-5 py-2.5 rounded-full font-bold text-sm transition transform hover:scale-105">
            Strava
          </a>
        </div>
      </div>
    </nav>