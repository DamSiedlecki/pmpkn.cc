---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TripCard from '../../../components/TripCard.astro';

const trips = (await getCollection('trip', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
})).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog Rowerowy - Najnowsze wpisy">
  <main class="max-w-6xl mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-5xl font-black text-slate-900 dark:text-white mb-4 text-balance transition-colors">
        <span class="text-orange-500">Trasy rowerowe</span> kujawsko pomorskie
      </h1>
      <p class="text-lg text-slate-600 dark:text-slate-400 transition-colors">Trasy rowerowe w regionie kujawsko pomorskim</p>
    </header>
      <h2 class="text-4xl font-black text-slate-900 dark:text-white mb-4 text-balance transition-colors">
        <span class="text-orange-500">Lokalizacje</span> tras
      </h2>
      
      
      <h2 class="text-4xl font-black text-slate-900 dark:text-white mb-4 text-balance transition-colors">
        <span class="text-orange-500">Ostatnio dodane</span> 
      </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {trips.map(trip => <TripCard trip={trip} />)}
    </div>
  </main>
</BaseLayout>