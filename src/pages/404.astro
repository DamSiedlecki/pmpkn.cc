---
// src/pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Nie znaleziono strony (404)">
  <section class="max-w-4xl mx-auto px-4 py-32 text-center flex flex-col items-center justify-center min-h-[60vh]">
    <div class="text-9xl font-black text-slate-200 dark:text-slate-800 mb-4 tracking-tighter transition-colors">404</div>
    <h1 class="text-4xl font-black text-slate-900 dark:text-white mb-6 uppercase transition-colors">Ups! Zjechałeś ze szlaku.</h1>
    <p class="text-lg text-slate-600 dark:text-slate-400 mb-10 max-w-lg transition-colors">
      Strona, której szukasz, nie istnieje, została przeniesiona lub... złapała gumę. 
    </p>
    
    <a href="/" class="bg-orange-600 hover:bg-orange-700 text-white px-8 py-4 rounded-full font-bold transition shadow-lg shadow-orange-900/20">
      Wróć na stronę główną
    </a>
  </section>
</BaseLayout>